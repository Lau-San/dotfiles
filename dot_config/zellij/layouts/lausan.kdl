layout {
    cwd "~/Projects/development/web/lausan"
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="file:~/.config/zellij/bin/zjstatus.wasm" {
                format_left   "{mode}#[bg=#181926] {tabs}"
                format_center ""
                format_right  "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#1e2030,bold]îž• #[bg=#363a4f,fg=#89b4fa,bold] {session}#[bg=#181926,fg=#363a4f,bold]#[bg=#181926,fg=#363a4f]î‚´"
                format_space  ""
                format_hide_on_overlength "true"
                format_precedence "crl"

                border_enabled  "false"
                border_char     "â”€"
                border_format   "#[fg=#6C7086]{char}"
                border_position "top"

                mode_normal        "#[bg=#181926,fg=#a6da95]î‚¶#[bg=#a6da95,fg=#181926,bold]NORMAL#[bg=#181926,fg=#a6da95]î‚´"
                mode_locked        "#[bg=#181926,fg=#6e738d]î‚¶#[bg=#6e738d,fg=#181926,bold]LOCKED ï€£#[bg=#181926,fg=#6e738d]î‚´"
                mode_resize        "#[bg=#181926,fg=#f38ba8]î‚¶#[bg=#f38ba8,fg=#181926,bold]RESIZE#[bg=#181926,fg=#f38ba8]î‚´"
                mode_pane          "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#181926,bold]PANE#[bg=#181926,fg=#89b4fa]î‚´"
                mode_tab           "#[bg=#181926,fg=#b4befe]î‚¶#[bg=#b4befe,fg=#181926,bold]TAB#[bg=#181926,fg=#b4befe]î‚´"
                mode_scroll        "#[bg=#181926,fg=#f9e2af]î‚¶#[bg=#f9e2af,fg=#181926,bold]SCROLL#[bg=#181926,fg=#f9e2af]î‚´"
                mode_enter_search  "#[bg=#181926,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#181926,bold]ENT-SEARCH#[bg=#181926,fg=#8aadf4]î‚´"
                mode_search        "#[bg=#181926,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#181926,bold]SEARCHARCH#[bg=#181926,fg=#8aadf4]î‚´"
                mode_rename_tab    "#[bg=#181926,fg=#b4befe]î‚¶#[bg=#b4befe,fg=#181926,bold]RENAME-TAB#[bg=#181926,fg=#b4befe]î‚´"
                mode_rename_pane   "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#181926,bold]RENAME-PANE#[bg=#181926,fg=#89b4fa]î‚´"
                mode_session       "#[bg=#181926,fg=#74c7ec]î‚¶#[bg=#74c7ec,fg=#181926,bold]SESSION#[bg=#181926,fg=#74c7ec]î‚´"
                mode_move          "#[bg=#181926,fg=#f5c2e7]î‚¶#[bg=#f5c2e7,fg=#181926,bold]MOVE#[bg=#181926,fg=#f5c2e7]î‚´"
                mode_prompt        "#[bg=#181926,fg=#8aadf4]î‚¶#[bg=#8aadf4,fg=#181926,bold]PROMPT#[bg=#181926,fg=#8aadf4]î‚´"
                mode_tmux          "#[bg=#181926,fg=#f5a97f]î‚¶#[bg=#f5a97f,fg=#181926,bold]TMUX#[bg=#181926,fg=#f5a97f]î‚´"

                // formatting for inactive tabs
                tab_normal              "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#89b4fa,bold] {name}{floating_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"
                tab_normal_fullscreen   "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#89b4fa,bold] {name}{fullscreen_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"
                tab_normal_sync         "#[bg=#181926,fg=#89b4fa]î‚¶#[bg=#89b4fa,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#89b4fa,bold] {name}{sync_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"

                // formatting for the current active tab
                tab_active              "#[bg=#181926,fg=#fab387]î‚¶#[bg=#fab387,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#fab387,bold] {name}{floating_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"
                tab_active_fullscreen   "#[bg=#181926,fg=#fab387]î‚¶#[bg=#fab387,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#fab387,bold] {name}{fullscreen_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"
                tab_active_sync         "#[bg=#181926,fg=#fab387]î‚¶#[bg=#fab387,fg=#1e2030,bold]{index} #[bg=#363a4f,fg=#fab387,bold] {name}{sync_indicator}#[bg=#181926,fg=#363a4f,bold]î‚´"

                // separator between the tabs
                tab_separator           "#[bg=#181926] "

                // indicators
                tab_sync_indicator       " ï‘ƒ"
                tab_fullscreen_indicator " ó°Š“"
                tab_floating_indicator   " ó°¹™"

                command_git_branch_command     "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format      "#[fg=blue] {stdout} "
                command_git_branch_interval    "10"
                command_git_branch_rendermode  "static"

                datetime        "#[fg=#6C7086,bold] {format} "
                datetime_format "%A, %d %b %Y %H:%M"
            }
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="code" split_direction="vertical" focus=true {
        pane command="nvim" size="60%"
        pane stacked=true {
            pane command="npm" {
                args "run" "dev"
            }
            pane command="npm" expanded=true {
                args "run" "storybook"
            }
            pane
        }
    }
}
