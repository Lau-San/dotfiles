(defwidget cal []
    (box          :class "cal_box"
                  :orientation "v"
      (box        :class "cal_inner_box"
        (calendar :class "cal"
                  :day calendar_day
                  :month calendar_month
                  :year calendar_year))))

(defwindow calendar [monitor]
    :monitor monitor
    :geometry (geometry :x "10px"
                        :y "10px"
                        :anchor "top right"
                        :width "270px"
                        :height "60px")
  (cal))

(defwindow calendar1
    :monitor 1
    :geometry (geometry :x "10px"
                        :y "10px"
                        :anchor "top right"
                        :width "270px"
                        :height "60px")
  (cal2))
