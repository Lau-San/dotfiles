{
    "ignore_mouse": true,
    "ui": {
        "icons": { "size": 38, "image_size": 150 },
        "orientation": "vertical",
        "ignore_exclusive": false,
        "fullscreen": false,
        "horizontal": "start",
        "vertical": "fill",
        "width": 600,
        "margins": {
            "top": 0
        },
        "anchors": {
            "top": true,
            "left": true,
            "bottom": true
        }
    },
    "list": {
        "always_show": true,
        "fixed_height": true,
        "height": 1000,
        "margin_top": 10,
        "max_entries": 0,
        "scrollbar_policy": "never",
        "show_initial_entries": true,
        "width": 600
    },
    "search": {
        "force_keyboard_focus": true,
        "icons": true,
        "history": true,
        "placeholder": "Search...",
        "delay": 0
    },
    "activation_mode": {
        "disabled": true
    },
    "builtins": {
        "applications": { "actions": false, "prioritize_new": true },
        "clipboard": {
            "image_height": 300,
            "max_entries": 10,
            "switcher_only": true
        },
        "commands": { "switcher_only": true },
        "custom_commands": {},
        "emojis": { "switcher_only": true, "history": true, "typeahead": true },
        "finder": { "switcher_only": true },
        "hyprland": { "context_aware_history": true },
        "runner": {
            "typeahead": true,
            "history": true,
            "generic_entry": false
        },
        "ssh": { "switcher_only": true, "history": true },
        "switcher": { "prefix": "/" },
        "websearch": { "engines": ["google"] }
    },
    "plugins": [
        {
            "name": "config",
            "src": "python /home/laura/.config/walker/plugins/config.py",
            "placeholder": "Search configuration"
        }
    ]
}
